<windowing:FAAppWindow x:Class="DirectorPrompt.Views.ChangelogWindow"
                       xmlns="https://github.com/avaloniaui"
                       xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                       xmlns:components="using:DirectorPrompt.Views.Components"
                       xmlns:windowing="using:FluentAvalonia.UI.Windowing"
                       xmlns:fa="using:FluentAvalonia.UI.Controls"
                       Width="720" Height="640" MinWidth="480" MinHeight="360"
                       Icon="/Assets/Images/Icon-NoBackground.ico"
                       WindowStartupLocation="CenterOwner" TransparencyLevelHint="Mica">
    <Grid RowDefinitions="Auto,*,Auto" Margin="24">
        <!-- 头部区域：更新日志图标和说明 -->
        <Grid Grid.Row="0" ColumnDefinitions="Auto,*" Margin="0,0,0,16">
            <!-- 圆形渐变背景图标 -->
            <Border Grid.Column="0" Width="40" Height="40" CornerRadius="20" Margin="0,0,16,0">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
                        <GradientStop Offset="0" Color="#0078D4" />
                        <GradientStop Offset="1" Color="#00B4D8" />
                    </LinearGradientBrush>
                </Border.Background>
                <fa:FASymbolIcon Symbol="Document" FontSize="18" Foreground="White" HorizontalAlignment="Center"
                                 VerticalAlignment="Center" />
            </Border>
            <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="4">
                <TextBlock Text="更新日志" FontSize="16" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                <TextBlock Text="查看当前版本的新增功能和优化内容" FontSize="12"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
            </StackPanel>
        </Grid>

        <!-- 主内容区：使用漂亮的卡片 Border 包裹 LiveMarkdownView -->
        <Border Grid.Row="1" CornerRadius="8"
                Background="{DynamicResource ContentDialogBackground}"
                BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                Padding="16"
                BoxShadow="0 4 16 0 #15000000">
            <ScrollViewer>
                <components:LiveMarkdownView x:Name="ChangelogViewer" />
            </ScrollViewer>
        </Border>

        <!-- 底部按钮区 -->
        <Grid Grid.Row="2" Margin="0,16,0,0">
            <Button HorizontalAlignment="Right"
                    Content="关闭"
                    Classes="accent"
                    MinWidth="90"
                    Click="OnCloseClick" />
        </Grid>
    </Grid>
</windowing:FAAppWindow>
