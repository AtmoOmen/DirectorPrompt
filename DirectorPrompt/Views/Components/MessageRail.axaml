<UserControl x:Class="DirectorPrompt.Views.Components.MessageRail"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:fa="using:FluentAvalonia.UI.Controls"
             xmlns:loc="clr-namespace:DirectorPrompt.Localization"
             ClipToBounds="False"
             PointerEntered="OnRailPointerEntered"
             PointerExited="OnRailPointerExited">
    <UserControl.Styles>
        <!-- 默认状态：折叠的 Border -->
        <Style Selector="Border#RailBorder">
            <Setter Property="Width" Value="16" />
            <Setter Property="Background" Value="#0C808080" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="Margin" Value="0,0,2,0" />
            <!-- 展开/收起过渡动画 -->
            <Setter Property="Transitions">
                <Transitions>
                    <DoubleTransition Property="Width" Duration="0:0:0.15" Easing="QuadraticEaseOut" />
                    <BrushTransition Property="Background" Duration="0:0:0.15" />
                    <BrushTransition Property="BorderBrush" Duration="0:0:0.15" />
                </Transitions>
            </Setter>
        </Style>

        <!-- 悬浮状态：展开的 Border -->
        <Style Selector="UserControl:pointerover Border#RailBorder">
            <Setter Property="Width" Value="40" />
            <Setter Property="Background" Value="{DynamicResource CardBackgroundFillColorDefaultBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource CardStrokeColorDefaultBrush}" />
            <Setter Property="BorderThickness" Value="1,0,0,0" />
            <Setter Property="BoxShadow" Value="0 4 12 0 #20000000" />
        </Style>

        <!-- 圆角矩形指示器（ListBoxItem）的默认样式 -->
        <Style Selector="ListBoxItem">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Height" Value="8" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Stretch" />
        </Style>

        <!-- 覆盖默认的 ListBoxItem 悬停与选中时的白色半透明背景板 -->
        <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent" />
        </Style>
        <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent" />
        </Style>
        <Style Selector="ListBoxItem:selected:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent" />
        </Style>

        <!-- 指示器默认外观：细而短的圆角矩形 -->
        <Style Selector="Border.indicator">
            <Setter Property="Width" Value="10" />
            <Setter Property="Height" Value="2" />
            <Setter Property="Background" Value="{DynamicResource TextFillColorTertiaryBrush}" />
            <Setter Property="Opacity" Value="0.4" />
            <Setter Property="CornerRadius" Value="99" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <!-- 交互过渡动画 -->
            <Setter Property="Transitions">
                <Transitions>
                    <DoubleTransition Property="Width" Duration="0:0:0.12" Easing="QuadraticEaseOut" />
                    <DoubleTransition Property="Height" Duration="0:0:0.12" Easing="QuadraticEaseOut" />
                    <DoubleTransition Property="Opacity" Duration="0:0:0.12" />
                    <BrushTransition Property="Background" Duration="0:0:0.12" />
                </Transitions>
            </Setter>
        </Style>

        <!-- 悬浮在侧栏时：所有指示器微微变亮 -->
        <Style Selector="UserControl:pointerover Border.indicator">
            <Setter Property="Opacity" Value="0.7" />
        </Style>

        <!-- 非悬浮状态下的当前项高亮指示（Selected）：比普通项更宽更长，Accent 高亮 -->
        <Style Selector="ListBoxItem:selected Border.indicator">
            <Setter Property="Width" Value="16" />
            <Setter Property="Height" Value="3" />
            <Setter Property="CornerRadius" Value="99" />
            <Setter Property="Background" Value="{DynamicResource AccentFillColorDefaultBrush}" />
            <Setter Property="Opacity" Value="1.0" />
        </Style>

        <!-- 悬浮在侧栏时，当前被鼠标悬停的对应项（PointerOver）：颜色高亮，只变亮不改变尺寸 -->
        <Style Selector="ListBoxItem:pointerover Border.indicator">
            <Setter Property="Background" Value="{DynamicResource AccentFillColorDefaultBrush}" />
            <Setter Property="Opacity" Value="1.0" />
        </Style>

        <!-- 针对特定的特殊消息点样式，例如导演消息（director）或错误消息（error） -->
        <Style Selector="Border.indicator.director">
            <Setter Property="Background" Value="{DynamicResource AccentFillColorDefaultBrush}" />
        </Style>
        <Style Selector="Border.indicator.error">
            <Setter Property="Background" Value="{DynamicResource SystemFillColorCriticalBrush}" />
        </Style>
        <Style Selector="Border.indicator.streaming">
            <Setter Property="Width" Value="6" />
            <Setter Property="Height" Value="2" />
        </Style>
        <Style Selector="UserControl.mobile Border#RailBorder">
            <Setter Property="Width" Value="36" />
            <Setter Property="Background" Value="{DynamicResource CardBackgroundFillColorDefaultBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource CardStrokeColorDefaultBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BoxShadow" Value="0 2 8 0 #28000000" />
        </Style>
        <Style Selector="UserControl.mobile ListBoxItem">
            <Setter Property="Height" Value="24" />
        </Style>
        <Style Selector="UserControl.mobile Border.indicator">
            <Setter Property="Width" Value="18" />
            <Setter Property="Height" Value="4" />
            <Setter Property="Opacity" Value="0.65" />
        </Style>
        <Style Selector="UserControl.mobile ListBoxItem:selected Border.indicator">
            <Setter Property="Width" Value="26" />
            <Setter Property="Height" Value="5" />
        </Style>

        <!-- 图标按钮样式 -->
        <Style Selector="Button.rail-btn">
            <Setter Property="Width" Value="28" />
            <Setter Property="Height" Value="28" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Opacity" Value="0.4" />
            <Setter Property="IsHitTestVisible" Value="True" />
            <Setter Property="Transitions">
                <Transitions>
                    <DoubleTransition Property="Opacity" Duration="0:0:0.12" Easing="QuadraticEaseOut" />
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="UserControl:pointerover Button.rail-btn">
            <Setter Property="Opacity" Value="0.7" />
        </Style>
        <Style Selector="Button.rail-btn:pointerover">
            <Setter Property="Opacity" Value="1.0" />
            <Setter Property="Background" Value="{DynamicResource ButtonBackgroundThemeBrushPressed}" />
        </Style>
        <Style Selector="UserControl.mobile Button.rail-btn">
            <Setter Property="Opacity" Value="0.8" />
            <Setter Property="IsHitTestVisible" Value="True" />
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="Auto,*,Auto" ClipToBounds="False" HorizontalAlignment="Right">
        <!-- 背景板：平滑宽度与毛玻璃质感过渡 -->
        <Border x:Name="RailBorder"
                Grid.Row="1"
                HorizontalAlignment="Center"
                ClipToBounds="False" />

        <!-- 顶部跳转按钮 -->
        <Button x:Name="GoToTopButton"
                Grid.Row="0"
                Classes="rail-btn"
                Margin="0,0,0,6"
                Click="OnGoToTopClick"
                ToolTip.Tip="{Binding [Dialog.GoToTop], Source={x:Static loc:Loc.Instance}}">
            <fa:FASymbolIcon Symbol="ChevronUp" FontSize="14" />
        </Button>

        <!-- 指示轨列表：保持固定宽度，居中对齐，不被任何容器裁剪 -->
        <ListBox x:Name="RailListBox"
                 Grid.Row="1"
                 Width="40"
                 HorizontalAlignment="Center"
                 ClipToBounds="False"
                 ItemsSource="{Binding Entries, RelativeSource={RelativeSource AncestorType=UserControl}}"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 ScrollViewer.VerticalScrollBarVisibility="Hidden"
                 Background="Transparent"
                 BorderThickness="0"
                 Padding="0,4"
                 Focusable="False"
                 SelectionMode="Single">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Grid Background="Transparent"
                          PointerPressed="OnRailItemPointerPressed"
                          ToolTip.Placement="Left"
                          ClipToBounds="False">
                        <ToolTip.Tip>
                            <StackPanel MaxWidth="300">
                                <TextBlock Text="{Binding Role}"
                                           FontWeight="SemiBold"
                                           FontSize="11"
                                           Margin="0,0,0,4" />
                                <TextBlock Text="{Binding Preview}"
                                           TextWrapping="Wrap"
                                           FontSize="12" />
                            </StackPanel>
                        </ToolTip.Tip>
                        <Border Classes="indicator"
                                Classes.director="{Binding IsDirector}"
                                Classes.error="{Binding HasError}"
                                Classes.streaming="{Binding IsStreaming}" />
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- 底部跳转按钮 -->
        <Button x:Name="GoToBottomButton"
                Grid.Row="2"
                Classes="rail-btn"
                Margin="0,6,0,0"
                Click="OnGoToBottomClick"
                ToolTip.Tip="{Binding [Dialog.GoToBottom], Source={x:Static loc:Loc.Instance}}">
            <fa:FASymbolIcon Symbol="ChevronDown" FontSize="14" />
        </Button>
    </Grid>
</UserControl>
