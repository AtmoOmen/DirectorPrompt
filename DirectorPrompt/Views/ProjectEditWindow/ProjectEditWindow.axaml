<windowing:FAAppWindow x:Class="DirectorPrompt.Views.ProjectEditWindow"
                        xmlns="https://github.com/avaloniaui"
                        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                        xmlns:fa="using:FluentAvalonia.UI.Controls"
                        xmlns:vm="clr-namespace:DirectorPrompt.ViewModels"
                        xmlns:loc="clr-namespace:DirectorPrompt.Localization"
                        xmlns:components="clr-namespace:DirectorPrompt.Views.Components"
                        xmlns:views="using:DirectorPrompt.Views"
                        xmlns:windowing="using:FluentAvalonia.UI.Windowing"
                        mc:Ignorable="d"
                        d:DataContext="{d:DesignInstance Type=vm:ProjectEditViewModel}"
                        Title="{Binding [Project.EditTitle], Source={x:Static loc:Loc.Instance}}"
                        Width="1000"
                        Height="720"
                        MinWidth="800"
                        MinHeight="600"
                        Icon="/Assets/Images/Icon-NoBackground.ico"
                        TransparencyLevelHint="Mica">
    <Grid x:Name="RootLayout" RowDefinitions="Auto,*,Auto">
        <Grid.Styles>
            <Style Selector="Border#RemoteNavHost">
                <Setter Property="IsVisible" Value="False" />
            </Style>
            <Style Selector="Border#ContentPanel">
                <Setter Property="BorderThickness" Value="1,0,0,0" />
            </Style>
            <Style Selector="Grid#RootLayout.remote Border#RemoteNavHost">
                <Setter Property="IsVisible" Value="True" />
            </Style>
            <Style Selector="Grid#RootLayout.remote ListBox#NavList">
                <Setter Property="IsVisible" Value="False" />
            </Style>
            <Style Selector="Grid#RootLayout.remote Border#ContentPanel">
                <Setter Property="BorderThickness" Value="0" />
            </Style>
        </Grid.Styles>

        <Border x:Name="RemoteNavHost" Grid.Row="0">
            <components:PathComboBox x:Name="RemoteNavComboBox"
                                     Margin="12,8"
                                     HorizontalAlignment="Stretch"
                                     SelectionChanged="OnRemoteNavSelectionChanged"
                                     SelectedIndex="0">
                <ComboBoxItem Content="{Binding [Project.Basic.Title], Source={x:Static loc:Loc.Instance}}" />
                <ComboBoxItem Content="{Binding [Knowledge.Title], Source={x:Static loc:Loc.Instance}}" />
                <ComboBoxItem Content="{Binding [State.Title], Source={x:Static loc:Loc.Instance}}" />
                <ComboBoxItem Content="{Binding [Character.Title], Source={x:Static loc:Loc.Instance}}" />
            </components:PathComboBox>
        </Border>

        <DockPanel Grid.Row="1">
            <ListBox DockPanel.Dock="Left"
                     x:Name="NavList"
                     Width="220"
                     MinWidth="180"
                     Background="{DynamicResource ControlFillColorTransparentBrush}"
                     BorderThickness="0"
                     Padding="4"
                     SelectionChanged="OnNavSelectionChanged"
                     SelectedIndex="0">
                <ListBoxItem Tag="basic" Padding="12,10">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <fa:FASymbolIcon Symbol="Edit" />
                        <TextBlock Text="{Binding [Project.Basic.Title], Source={x:Static loc:Loc.Instance}}"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </ListBoxItem>
                <ListBoxItem Tag="knowledge" Padding="12,10">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <fa:FASymbolIcon Symbol="Library" />
                        <TextBlock Text="{Binding [Knowledge.Title], Source={x:Static loc:Loc.Instance}}"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </ListBoxItem>
                <ListBoxItem Tag="state" Padding="12,10">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <fa:FASymbolIcon Symbol="View" />
                        <TextBlock Text="{Binding [State.Title], Source={x:Static loc:Loc.Instance}}"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </ListBoxItem>
                <ListBoxItem Tag="character" Padding="12,10">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <fa:FASymbolIcon Symbol="People" />
                        <TextBlock Text="{Binding [Character.Title], Source={x:Static loc:Loc.Instance}}"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </ListBoxItem>
            </ListBox>

            <Border x:Name="ContentPanel"
                    BorderBrush="{DynamicResource ControlElevationBorderBrush}">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              Padding="24,12,24,16">
                    <Grid>
                        <!-- 基本信息 -->
                        <views:ProjectBasicEditView x:Name="BasicPanel" IsVisible="True" />

                        <!-- 知识系统 (树状) -->
                        <views:ProjectKnowledgeEditView x:Name="KnowledgePanel" IsVisible="False" />

                        <!-- 状态系统 -->
                        <views:ProjectStateEditView x:Name="StatePanel" IsVisible="False" />

                        <!-- 人物系统 -->
                        <views:ProjectCharacterEditView x:Name="CharacterPanel" IsVisible="False" />
                    </Grid>
                </ScrollViewer>
            </Border>
        </DockPanel>

        <Border Grid.Row="2"
                BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="24,12">
            <Grid ColumnDefinitions="*,Auto">

                <TextBlock Grid.Column="0"
                           Text="{Binding ValidationMessage}"
                           Foreground="OrangeRed"
                           VerticalAlignment="Center"
                           TextWrapping="Wrap" />

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal">
                    <Button Margin="0,0,8,0"
                            Click="OnCancelClick"
                            IsEnabled="{Binding IsSaving, Converter={StaticResource InverseBool}}">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <fa:FASymbolIcon Symbol="Dismiss" />
                            <TextBlock Text="{Binding [Common.Cancel], Source={x:Static loc:Loc.Instance}}" />
                        </StackPanel>
                    </Button>
                    <Button Click="OnSaveClick" IsEnabled="{Binding IsSaving, Converter={StaticResource InverseBool}}">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <fa:FASymbolIcon Symbol="Save" />
                            <TextBlock Text="{Binding [Common.Save], Source={x:Static loc:Loc.Instance}}" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</windowing:FAAppWindow>
