<windowing:FAAppWindow x:Class="DirectorPrompt.Views.SettingsWindow"
                       xmlns="https://github.com/avaloniaui"
                       xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                       xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                       xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                       xmlns:fa="using:FluentAvalonia.UI.Controls"
                       xmlns:vm="clr-namespace:DirectorPrompt.ViewModels"
                       xmlns:loc="clr-namespace:DirectorPrompt.Localization"
                       xmlns:components="clr-namespace:DirectorPrompt.Views.Components"
                       xmlns:windowing="using:FluentAvalonia.UI.Windowing"
                       xmlns:settings="clr-namespace:DirectorPrompt.Views.Settings"
                       mc:Ignorable="d"
                       d:DataContext="{d:DesignInstance Type=vm:SettingsViewModel}"
                       Title="{Binding [Settings.Title], Source={x:Static loc:Loc.Instance}}"
                       Width="960"
                       Height="800"
                       MinWidth="600"
                       MinHeight="480"
                       Icon="/Assets/Images/Icon-NoBackground.ico"
                       TransparencyLevelHint="Mica">
    <Grid x:Name="RootLayout" RowDefinitions="Auto,*,Auto">
        <Grid.Styles>
            <Style Selector="Border#RemoteNavHost">
                <Setter Property="IsVisible" Value="False" />
            </Style>
            <Style Selector="Border#ContentPanel">
                <Setter Property="BorderThickness" Value="1,0,0,0" />
            </Style>
            <Style Selector="Grid#RootLayout.remote Border#RemoteNavHost">
                <Setter Property="IsVisible" Value="True" />
            </Style>
            <Style Selector="Grid#RootLayout.remote ListBox#NavList">
                <Setter Property="IsVisible" Value="False" />
            </Style>
            <Style Selector="Grid#RootLayout.remote Border#ContentPanel">
                <Setter Property="BorderThickness" Value="0" />
            </Style>
        </Grid.Styles>

        <Border x:Name="RemoteNavHost" Grid.Row="0">
            <components:PathComboBox x:Name="RemoteNavComboBox"
                                     Margin="12,8"
                                     HorizontalAlignment="Stretch"
                                     SelectionChanged="OnRemoteNavSelectionChanged"
                                     SelectedIndex="0">
                <ComboBoxItem Content="{Binding [Settings.Provider.Title], Source={x:Static loc:Loc.Instance}}" />
                <ComboBoxItem Content="{Binding [Settings.Model.Title], Source={x:Static loc:Loc.Instance}}" />
                <ComboBoxItem Content="{Binding [Settings.Prompt.Title], Source={x:Static loc:Loc.Instance}}" />
                <ComboBoxItem Content="{Binding [Settings.Task.Title], Source={x:Static loc:Loc.Instance}}" />
                <ComboBoxItem Content="{Binding [Settings.MCP.Title], Source={x:Static loc:Loc.Instance}}" />
                <ComboBoxItem Content="{Binding [Settings.Embedding.Title], Source={x:Static loc:Loc.Instance}}" />
                <ComboBoxItem Content="{Binding [Memory.Title], Source={x:Static loc:Loc.Instance}}" />
                <ComboBoxItem Content="{Binding [Knowledge.Retrieval.Title], Source={x:Static loc:Loc.Instance}}" />
                <ComboBoxItem Content="{Binding [Settings.Others.Title], Source={x:Static loc:Loc.Instance}}" />
            </components:PathComboBox>
        </Border>

        <DockPanel Grid.Row="1">
            <ListBox DockPanel.Dock="Left"
                     x:Name="NavList"
                     Width="220"
                     MinWidth="180"
                     Background="{DynamicResource ControlFillColorTransparentBrush}"
                     BorderThickness="0"
                     Padding="4"
                     SelectionChanged="OnNavSelectionChanged"
                     SelectedIndex="0">
                <ListBoxItem Tag="providers" Padding="12,10">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <fa:FASymbolIcon Symbol="Cloud" />
                        <TextBlock Text="{Binding [Settings.Provider.Title], Source={x:Static loc:Loc.Instance}}"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </ListBoxItem>
                <ListBoxItem Tag="models" Padding="12,10">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <fa:FASymbolIcon Symbol="People" />
                        <TextBlock Text="{Binding [Settings.Model.Title], Source={x:Static loc:Loc.Instance}}"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </ListBoxItem>
                <ListBoxItem Tag="prompts" Padding="12,10">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <fa:FASymbolIcon Symbol="Document" />
                        <TextBlock Text="{Binding [Settings.Prompt.Title], Source={x:Static loc:Loc.Instance}}"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </ListBoxItem>
                <ListBoxItem Tag="tasks" Padding="12,10">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <fa:FASymbolIcon Symbol="Bullets" />
                        <TextBlock Text="{Binding [Settings.Task.Title], Source={x:Static loc:Loc.Instance}}"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </ListBoxItem>
                <ListBoxItem Tag="mcp" Padding="12,10">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <fa:FASymbolIcon Symbol="Globe" />
                        <TextBlock Text="{Binding [Settings.MCP.Title], Source={x:Static loc:Loc.Instance}}"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </ListBoxItem>
                <ListBoxItem Tag="embedding" Padding="12,10">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <fa:FASymbolIcon Symbol="Library" />
                        <TextBlock Text="{Binding [Settings.Embedding.Title], Source={x:Static loc:Loc.Instance}}"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </ListBoxItem>
                <ListBoxItem Tag="memory" Padding="12,10">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <fa:FASymbolIcon Symbol="SaveLocal" />
                        <TextBlock Text="{Binding [Memory.Title], Source={x:Static loc:Loc.Instance}}"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </ListBoxItem>
                <ListBoxItem Tag="retrieval" Padding="12,10">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <fa:FASymbolIcon Symbol="Find" />
                        <TextBlock Text="{Binding [Knowledge.Retrieval.Title], Source={x:Static loc:Loc.Instance}}"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </ListBoxItem>
                <ListBoxItem Tag="others" Padding="12,10">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <fa:FASymbolIcon Symbol="Setting" />
                        <TextBlock Text="{Binding [Settings.Others.Title], Source={x:Static loc:Loc.Instance}}"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </ListBoxItem>
            </ListBox>

            <Border x:Name="ContentPanel"
                    BorderBrush="{DynamicResource ControlElevationBorderBrush}">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              Padding="24,12,24,16">
                    <Grid>
                        <settings:ProvidersSettingsView x:Name="ProvidersPanel" IsVisible="True" />
                        <settings:ModelsSettingsView x:Name="ModelsPanel" IsVisible="False" />
                        <settings:PromptsSettingsView x:Name="PromptsPanel" IsVisible="False" />
                        <settings:TasksSettingsView x:Name="TasksPanel" IsVisible="False" />
                        <settings:MCPSettingsView x:Name="MCPPanel" IsVisible="False" />
                        <settings:EmbeddingSettingsView x:Name="EmbeddingPanel" IsVisible="False" />
                        <settings:MemorySettingsView x:Name="MemoryPanel" IsVisible="False" />
                        <settings:RetrievalSettingsView x:Name="RetrievalPanel" IsVisible="False" />
                        <settings:OthersSettingsView x:Name="OthersPanel" IsVisible="False" />
                    </Grid>
                </ScrollViewer>
            </Border>
        </DockPanel>

        <Border Grid.Row="2"
                BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="24,12">
            <Grid ColumnDefinitions="*,Auto">

                <TextBlock Grid.Column="0"
                           Text="{Binding ValidationMessage}"
                           Foreground="OrangeRed"
                           VerticalAlignment="Center"
                           TextWrapping="Wrap" />

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal">
                    <Button Margin="0,0,8,0" Click="OnCancelClick">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <fa:FASymbolIcon Symbol="Dismiss" />
                            <TextBlock Text="{Binding [Common.Cancel], Source={x:Static loc:Loc.Instance}}" />
                        </StackPanel>
                    </Button>
                    <Button Click="OnSaveClick" IsEnabled="{Binding IsSaving, Converter={StaticResource InverseBool}}">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <fa:FASymbolIcon Symbol="Save" />
                            <TextBlock Text="{Binding [Common.Save], Source={x:Static loc:Loc.Instance}}" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</windowing:FAAppWindow>
