<UserControl x:Class="DirectorPrompt.Views.StatePanelControl"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:fa="using:FluentAvalonia.UI.Controls"
             xmlns:vm="clr-namespace:DirectorPrompt.ViewModels"
             xmlns:loc="clr-namespace:DirectorPrompt.Localization"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:MainViewModel}">
    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,8,0,0">
        <StackPanel>
            <Expander IsExpanded="True" Margin="0,0,0,8">
                <Expander.Header>
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <fa:FASymbolIcon Symbol="Play" FontSize="14"
                                         Foreground="{DynamicResource AccentTextFillColorPrimaryBrush}" />
                        <TextBlock
                            Text="{Binding [State.Panel.Title], Source={x:Static loc:Loc.Instance}}"
                            FontWeight="SemiBold" />
                    </StackPanel>
                </Expander.Header>
                <StackPanel>
                    <Grid Margin="0,2" ColumnDefinitions="Auto,*">
                        <TextBlock Grid.Column="0"
                                   Text="{Binding [State.Panel.Scene], Source={x:Static loc:Loc.Instance}}"
                                   Foreground="Gray" Margin="0,0,8,0" />
                        <TextBlock Grid.Column="1" Text="{Binding StatePanel.CurrentSceneLabel}" />
                    </Grid>
                    <ItemsControl ItemsSource="{Binding StatePanel.StateItems}" Margin="0,4,0,0">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,2" ColumnDefinitions="*,Auto">
                                    <TextBlock Grid.Column="0" Text="{Binding Name}"
                                               TextTrimming="CharacterEllipsis" />
                                    <TextBlock Grid.Column="1" Text="{Binding Value}"
                                               FontWeight="SemiBold"
                                               Margin="8,0,0,0" />
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Expander>

            <Expander IsExpanded="True" Margin="0,0,0,8">
                <Expander.Header>
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <fa:FASymbolIcon Symbol="Message" FontSize="14"
                                         Foreground="{DynamicResource AccentTextFillColorPrimaryBrush}" />
                        <TextBlock
                            Text="{Binding [Directive.Panel.Title], Source={x:Static loc:Loc.Instance}}"
                            FontWeight="SemiBold" />
                    </StackPanel>
                </Expander.Header>
                <ItemsControl ItemsSource="{Binding DirectivesPanel.Directives}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="0,2"
                                    Padding="8,4"
                                    Background="{DynamicResource ControlFillColorDefaultBrush}"
                                    CornerRadius="4">
                                <StackPanel>
                                    <DockPanel>
                                        <TextBlock Text="{Binding Type}" Margin="0,0,4,0"
                                                   DockPanel.Dock="Left" VerticalAlignment="Top" />
                                        <TextBlock Text="{Binding Content}" TextWrapping="Wrap"
                                                   VerticalAlignment="Top" />
                                    </DockPanel>
                                    <TextBlock Text="{Binding TTLLabel}"
                                               FontSize="11"
                                               Foreground="Gray"
                                               IsVisible="{Binding HasTTL, Converter={StaticResource BoolToVisibility}}" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Expander>
        </StackPanel>
    </ScrollViewer>
</UserControl>
